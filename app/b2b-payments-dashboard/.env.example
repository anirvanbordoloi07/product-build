# ==============================================================================
# B2B Payments Analytics Dashboard — Environment Variable Template
# ==============================================================================
# Copy this file to .env and fill in all required values before running.
# NEVER commit a .env file with real secrets to version control.
#
# Naming conventions:
#   - Required values are marked # REQUIRED
#   - Values safe to use as-is in local dev are pre-filled
#   - Secret values are left blank and marked accordingly
# ==============================================================================


# ------------------------------------------------------------------------------
# Application Core
# ------------------------------------------------------------------------------

NODE_ENV=development                             # development | staging | production
APP_URL=http://localhost:3000                    # Public-facing web app URL
API_URL=http://localhost:8080                    # Internal API base URL
PORT=8080                                        # API service listening port
LOG_LEVEL=debug                                  # debug | info | warn | error
CORS_ORIGINS=http://localhost:3000               # Comma-separated allowed origins


# ------------------------------------------------------------------------------
# PostgreSQL (OLTP) — AWS Aurora v2 in production
# ------------------------------------------------------------------------------

DATABASE_URL=postgresql://dev:dev@localhost:5432/b2b_dashboard   # REQUIRED — Prisma connection string
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=30000              # Kill queries exceeding 30s


# ------------------------------------------------------------------------------
# ClickHouse (OLAP)
# ------------------------------------------------------------------------------

CLICKHOUSE_URL=http://localhost:8123             # REQUIRED
CLICKHOUSE_DATABASE=b2b_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=                             # Leave blank for local dev default user
CLICKHOUSE_MAX_EXECUTION_TIME=30                 # Query timeout in seconds


# ------------------------------------------------------------------------------
# Redis (Cache + Sessions + Queues)
# ------------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379                 # REQUIRED
REDIS_CLUSTER=false                              # Set true in production (ElastiCache cluster mode)
REDIS_KEY_PREFIX=b2b:                            # Namespace prefix for all keys
REDIS_DEFAULT_TTL_SECONDS=300                    # Default cache TTL (5 minutes)


# ------------------------------------------------------------------------------
# Elasticsearch / OpenSearch (Full-Text Search)
# ------------------------------------------------------------------------------

ELASTICSEARCH_URL=http://localhost:9200          # REQUIRED
ELASTICSEARCH_INDEX_PREFIX=paymentiq_dev_        # Prefix for all indices
ELASTICSEARCH_USERNAME=                          # Leave blank for local dev
ELASTICSEARCH_PASSWORD=


# ------------------------------------------------------------------------------
# Authentication & Sessions
# ------------------------------------------------------------------------------

# JWT — Use asymmetric RS256 in production (key pair below); symmetric secret for local dev only
JWT_SECRET=change-me-to-a-64-char-random-hex-string-in-local-dev-only
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem     # Used in production (RS256)
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem       # Used in production (RS256)
JWT_EXPIRY=15m                                         # Access token TTL
REFRESH_TOKEN_EXPIRY=30d                               # Refresh token TTL
JWT_ISSUER=https://app.paymentiq.com

SESSION_SECRET=change-me-to-a-64-char-random-hex-string  # REQUIRED — cookie signing secret

# bcrypt cost factor (10–12 for local dev, 12 for production)
BCRYPT_ROUNDS=12


# ------------------------------------------------------------------------------
# SSO — SAML 2.0 / OAuth 2.0
# ------------------------------------------------------------------------------

# Google Workspace SAML
SAML_GOOGLE_ENTITY_ID=https://app.paymentiq.com
SAML_GOOGLE_SSO_URL=                             # From Google Admin → SAML App → SSO URL
SAML_GOOGLE_CERTIFICATE=                         # Base64-encoded PEM from Google Admin

# Microsoft Entra ID (Azure AD) SAML
SAML_MICROSOFT_ENTITY_ID=https://app.paymentiq.com
SAML_MICROSOFT_SSO_URL=                          # From Azure AD → Enterprise App → Login URL
SAML_MICROSOFT_CERTIFICATE=                      # Base64-encoded PEM from Azure AD

# Google OAuth 2.0 (for non-SAML Google SSO)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/oauth/google/callback

# Microsoft OAuth 2.0
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common              # Use 'common' for multi-tenant, specific tenant UUID for single-tenant
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8080/auth/oauth/microsoft/callback


# ------------------------------------------------------------------------------
# Apache Kafka (Amazon MSK in production)
# ------------------------------------------------------------------------------

KAFKA_BROKERS=localhost:9092                     # REQUIRED — comma-separated broker list
KAFKA_SECURITY_PROTOCOL=PLAINTEXT                # PLAINTEXT (local) | SASL_SSL (production)
KAFKA_SASL_MECHANISM=SCRAM-SHA-512               # Used when SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_USERNAME=                             # MSK SASL username
KAFKA_SASL_PASSWORD=                             # MSK SASL password
KAFKA_CLIENT_ID=b2b-dashboard-api
KAFKA_CONSUMER_GROUP_PREFIX=b2b-dashboard
KAFKA_SSL_CA_CERT_PATH=                          # Path to MSK CA cert in production


# ------------------------------------------------------------------------------
# AWS
# ------------------------------------------------------------------------------

AWS_REGION=us-east-1
# In production: use IAM Roles for Service Accounts (IRSA) on EKS — do NOT set these:
AWS_ACCESS_KEY_ID=                               # Local dev only
AWS_SECRET_ACCESS_KEY=                           # Local dev only

# S3 Buckets
S3_BUCKET_EXPORTS=b2b-dashboard-exports-dev
S3_BUCKET_RAW_INGESTION=b2b-dashboard-raw-dev
S3_BUCKET_ML_ARTIFACTS=b2b-dashboard-ml-artifacts-dev
S3_BUCKET_RECEIPTS=b2b-dashboard-receipts-dev
S3_PRESIGNED_URL_EXPIRY_SECONDS=900              # 15 minutes


# ------------------------------------------------------------------------------
# Temporal (Workflow Orchestration)
# ------------------------------------------------------------------------------

TEMPORAL_ADDRESS=localhost:7233                  # Temporal Cloud gRPC address in production
TEMPORAL_NAMESPACE=b2b-dashboard-dev
TEMPORAL_API_KEY=                                # Temporal Cloud API key (not needed for local)
TEMPORAL_TLS_ENABLED=false                       # Set true for Temporal Cloud
TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=


# ------------------------------------------------------------------------------
# Integration Credentials — Card / Spend Platforms
# ------------------------------------------------------------------------------

# Ramp
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=
RAMP_REDIRECT_URI=http://localhost:8080/integrations/ramp/callback
RAMP_WEBHOOK_SECRET=                             # HMAC-SHA256 secret from Ramp Developer Portal
RAMP_API_BASE_URL=https://api.ramp.com/developer/v1

# Brex
BREX_CLIENT_ID=
BREX_CLIENT_SECRET=
BREX_REDIRECT_URI=http://localhost:8080/integrations/brex/callback
BREX_WEBHOOK_SECRET=
BREX_API_BASE_URL=https://platform.brexapis.com

# American Express
AMEX_CLIENT_ID=
AMEX_CLIENT_SECRET=
AMEX_API_KEY=
AMEX_API_BASE_URL=https://api.americanexpress.com

# Navan
NAVAN_API_KEY=
NAVAN_CLIENT_ID=
NAVAN_CLIENT_SECRET=
NAVAN_REDIRECT_URI=http://localhost:8080/integrations/navan/callback
NAVAN_API_BASE_URL=https://api.navan.com


# ------------------------------------------------------------------------------
# Integration Credentials — AP / Payables Platforms
# ------------------------------------------------------------------------------

# Bill.com
BILLDOTCOM_CLIENT_ID=
BILLDOTCOM_CLIENT_SECRET=
BILLDOTCOM_DEVELOPER_KEY=
BILLDOTCOM_ENV=sandbox                           # sandbox | production
BILLDOTCOM_API_BASE_URL=https://api-sandbox.bill.com/api/v2

# Tipalti
TIPALTI_API_KEY=
TIPALTI_PAYER_NAME=
TIPALTI_API_BASE_URL=https://api.sandbox.tipalti.com  # Change for production

# Coupa
COUPA_CLIENT_ID=
COUPA_CLIENT_SECRET=
COUPA_BASE_URL=                                  # REQUIRED — https://yourcompany.coupahost.com
COUPA_REDIRECT_URI=http://localhost:8080/integrations/coupa/callback


# ------------------------------------------------------------------------------
# Integration Credentials — Banking
# ------------------------------------------------------------------------------

# Plaid
PLAID_CLIENT_ID=                                 # REQUIRED for banking features
PLAID_SECRET=                                    # REQUIRED
PLAID_ENV=sandbox                                # sandbox | development | production
PLAID_PRODUCTS=transactions,balance
PLAID_COUNTRY_CODES=US,CA
PLAID_REDIRECT_URI=http://localhost:3000/integrations/plaid/callback
PLAID_WEBHOOK_URL=http://localhost:8080/v1/webhooks/plaid

# JPMorgan Access API
JPMORGAN_CLIENT_ID=
JPMORGAN_CLIENT_SECRET=
JPMORGAN_MTLS_CERT_PATH=                         # Path to mTLS client certificate PEM
JPMORGAN_MTLS_KEY_PATH=                          # Path to mTLS client key PEM
JPMORGAN_API_BASE_URL=https://api-sandbox.jpmorgan.com


# ------------------------------------------------------------------------------
# Integration Credentials — ERP Systems
# ------------------------------------------------------------------------------

# NetSuite (Token-Based Authentication — OAuth 1.0a)
NETSUITE_ACCOUNT_ID=                             # e.g., 1234567 or 1234567_SB1 for sandbox
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=
NETSUITE_API_VERSION=2024_1

# QuickBooks Online
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox                          # sandbox | production
QBO_REDIRECT_URI=http://localhost:8080/integrations/quickbooks/callback
QBO_WEBHOOK_VERIFIER_TOKEN=                      # From Intuit Developer Portal

# SAP (S/4HANA Cloud)
SAP_BTP_CLIENT_ID=
SAP_BTP_CLIENT_SECRET=
SAP_BTP_TOKEN_URL=                               # https://{tenant}.authentication.eu10.hana.ondemand.com/oauth/token
SAP_S4HANA_BASE_URL=                             # https://{tenant}.s4hana.cloud.sap

# Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8080/integrations/xero/callback
XERO_WEBHOOK_KEY=                                # From Xero Developer Portal

# Workday
WORKDAY_TENANT=                                  # Your Workday tenant ID
WORKDAY_ISU_USERNAME=                            # Integration System User username
WORKDAY_ISU_PASSWORD=
WORKDAY_BASE_URL=                                # https://wd3.myworkday.com/yourco/...


# ------------------------------------------------------------------------------
# Communication Platforms
# ------------------------------------------------------------------------------

# Slack
SLACK_BOT_TOKEN=                                 # xoxb-... — Bot User OAuth Token
SLACK_SIGNING_SECRET=                            # For verifying incoming webhook requests
SLACK_CLIENT_ID=                                 # For Slack OAuth app installation
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8080/integrations/slack/callback

# Microsoft Teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=


# ------------------------------------------------------------------------------
# AI / ML — Anthropic Claude API
# ------------------------------------------------------------------------------

ANTHROPIC_API_KEY=                               # REQUIRED for categorization and narrative features
ANTHROPIC_MODEL_CATEGORIZATION=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_NARRATIVE=claude-opus-4-5
ANTHROPIC_MAX_TOKENS_CATEGORIZATION=256
ANTHROPIC_MAX_TOKENS_NARRATIVE=2048
ANTHROPIC_PROMPT_CACHE_ENABLED=true              # Enable prompt caching to reduce API costs


# ------------------------------------------------------------------------------
# ML / Feature Store
# ------------------------------------------------------------------------------

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=b2b-anomaly-detection
FEAST_REPO_PATH=/app/services/ml/feature_store

# Anomaly detection thresholds (can be overridden per org in DB)
ANOMALY_SCORE_ALERT_THRESHOLD=0.8                # 0.0–1.0; flag transactions above this
ANOMALY_MODEL_RETRAIN_DAYS=90                    # Days of history used for model training
ANOMALY_MIN_TRANSACTIONS_FOR_TRAINING=100        # Min transactions before org gets custom model


# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------

# Datadog
DD_API_KEY=
DD_APP_KEY=
DD_ENV=development
DD_SERVICE=b2b-dashboard-api
DD_VERSION=1.0.0
DD_TRACE_ENABLED=false                           # Set true in production
DD_LOGS_INJECTION=true

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=                                  # Set automatically in CI/CD from git SHA
SENTRY_TRACES_SAMPLE_RATE=0.1                   # 10% of requests; reduce cost in high-traffic prod

# LaunchDarkly
LAUNCHDARKLY_SDK_KEY=                            # Server-side SDK key
LAUNCHDARKLY_CLIENT_SIDE_ID=                     # Client-side ID for frontend


# ------------------------------------------------------------------------------
# Email (AWS SES)
# ------------------------------------------------------------------------------

SES_FROM_ADDRESS=noreply@paymentiq.com
SES_FROM_NAME=PaymentIQ
SES_REGION=us-east-1
SES_CONFIGURATION_SET=b2b-dashboard-transactional


# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------

RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=60            # Default per IP
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE_AUTHENTICATED=600   # Per authenticated user
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE_API_KEY=6000  # Per API key (partner integrations)


# ------------------------------------------------------------------------------
# Feature Flags (can also be managed in LaunchDarkly)
# ------------------------------------------------------------------------------

FEATURE_ML_CATEGORIZATION=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_CASH_FLOW_FORECAST=false                 # P1 feature — disabled until ML model is trained
FEATURE_MULTI_ENTITY=false                       # P1 feature — behind flag for phased rollout
FEATURE_REPORT_BUILDER=true
FEATURE_ERP_SYNC=true


# ------------------------------------------------------------------------------
# Multi-Tenancy
# ------------------------------------------------------------------------------

MAX_ORGS_PER_INSTANCE=10000                      # Soft limit; used for capacity planning alerts
DEFAULT_TRIAL_DAYS=14
MAX_INTEGRATIONS_STARTER_TIER=3
MAX_USERS_STARTER_TIER=50
MAX_INTEGRATIONS_GROWTH_TIER=999                 # Effectively unlimited
MAX_USERS_GROWTH_TIER=250


# ------------------------------------------------------------------------------
# Data Retention
# ------------------------------------------------------------------------------

RAW_INGESTION_RETENTION_DAYS=90                  # Days before S3 lifecycle → Glacier
REPORT_EXPORT_RETENTION_DAYS=90                  # Days before auto-delete from S3
SESSION_RETENTION_HOURS=24
AUDIT_LOG_RETENTION_YEARS=7
